{
  "manifest_version": 3,
  "name": "Job Autofill",
  "description": "Autofill job application forms from a JSON profile.",
  "version": "1.0",

  "permissions": [
    "storage",
    "activeTab"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "matcher.js",
        "content.js"
      ]
    }
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "libs/pdf/pdf.mjs",
        "libs/pdf/pdf.worker.mjs"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}